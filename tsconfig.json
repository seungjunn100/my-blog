{
  "compilerOptions": {
    "types": ["vite/client"], // Vite 전용 기능(import.meta.glob 등)을 TypeScript에서 인식하도록 하기 위한 타입 설정
    "target": "ES2020", // TypeScript가 어떤 자바스크립트 문법 수준까지 사용할지 설정
    "useDefineForClassFields": true, // 클래스 필드를 최신 JS 표준 방식으로 처리
    
    "lib": [ // TypeScript가 어떤 환경의 API를 알고 있을지 정의하는 설정
      "ES2020", // 자바스크립트 기본 기능 (Promise, Array, Map 등)
      "DOM", // 브라우저 API (window, document 등)
      "DOM.Iterable", // DOM 객체를 반복문에서 사용할 수 있게 하는 기능
    ],
    "module": "ESNext", // 모듈 시스템을 최신 ESM 방식으로 사용
    "moduleResolution": "Bundler", // Vite 같은 번들러 환경에 맞는 모듈 해석 방식 // './App'처럼 확장자 없이 import 가능

    "allowImportingTsExtensions": false, // .ts / .tsx 확장자를 import 경로에 직접 쓰지 않도록 설정
    "resolveJsonModule": true, // JSON 파일 import 허용 // 나중에 .generated/*.json 같은 파일을 다룰 때 유용
    "isolatedModules": true, // 각 파일이 독립적으로 안전하게 처리될 수 있는지 검사
    "noEmit": true, // TypeScript가 직접 JS 파일을 출력하지 않도록 설정 // 실제 빌드는 Vite가 담당

    "jsx": "react-jsx", // React JSX 최신 변환 방식 사용
    "strict": true, // 타입 체크를 엄격하게 수행
    "skipLibCheck": true, // 외부 라이브러리 타입 검사 일부 생략

    "noUncheckedIndexedAccess": true, // 배열/객체 접근 시 undefined 가능성을 더 엄격히 체크
    "exactOptionalPropertyTypes": true // optional 속성 타입을 더 엄격하게 체크
  },
  "include": ["src", "scripts", "vite.config.ts"] // TypeScript가 검사할 대상 파일/폴더
}